PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pm-tool?appName=pm-tool
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=http://localhost:3000
BACKEND_URL=https://your-render-service.onrender.com
NODE_ENV=development

# ── Email notifications (Gmail SMTP) ──────────────────────────────────────────
# Use your Gmail address + an App Password (not your real password).
# To create an App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ── WhatsApp notifications (Meta Cloud API) ───────────────────────────────────
# Free tier: 1,000 conversations/month.  Setup:
#   1. developers.facebook.com → Create App → Business → Add WhatsApp
#   2. Copy the temporary access token (or generate a permanent one)
#   3. Copy the Phone Number ID from the API setup screen
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
