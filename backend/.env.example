PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pm-tool?appName=pm-tool
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=http://localhost:3000
BACKEND_URL=https://your-render-service.onrender.com
NODE_ENV=development

# ── Email notifications ────────────────────────────────────────────────────────
# Works with Gmail OR any other SMTP provider (Outlook, Zoho, your own domain, etc.)
#
# Option A — Gmail (no EMAIL_HOST needed):
#   EMAIL_USER=you@gmail.com
#   EMAIL_PASS=xxxx-xxxx-xxxx-xxxx   ← Gmail App Password (not your real password)
#   How to get App Password: Google Account → Security → 2-Step Verification → App passwords
#
# Option B — Any other SMTP (Outlook, Zoho, cPanel, Brevo, etc.):
#   EMAIL_HOST=smtp.yourdomain.com   (e.g. smtp.office365.com / smtp.zoho.com)
#   EMAIL_PORT=587                   (587 for TLS, 465 for SSL)
#   EMAIL_SECURE=false               (set to true only for port 465)
#   EMAIL_USER=notifications@yourdomain.com
#   EMAIL_PASS=your-smtp-password
#   EMAIL_FROM=notifications@yourdomain.com   (optional; defaults to EMAIL_USER)
#
EMAIL_USER=you@example.com
EMAIL_PASS=your-smtp-password
# EMAIL_HOST=smtp.yourdomain.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_FROM=notifications@yourdomain.com

# ── WhatsApp notifications (Meta Cloud API) ───────────────────────────────────
# Free tier: 1,000 conversations/month.  Setup:
#   1. developers.facebook.com → Create App → Business → Add WhatsApp
#   2. Copy the temporary access token (or generate a permanent one)
#   3. Copy the Phone Number ID from the API setup screen
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
